# Lightsail production env. Copy to `.env` (next to docker-compose.prod.yml) on
# the box and fill in real values. This file is git-ignored — never commit .env.

# ---- Postgres password (used by the DB container AND the app's DB URLs) ----
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# ---- Security ----
# Long random string. Generate: openssl rand -hex 32
WB_JWT_SECRET=change-me-to-a-long-random-string

# ---- LLM provider ----
WB_LLM_PROVIDER=openai
WB_OPENAI_API_KEY=sk-...
# To use Gemini instead, set WB_LLM_PROVIDER=gemini and fill the key below.
WB_GOOGLE_API_KEY=

# ---- Travel providers ----
WB_DUFFEL_API_KEY=duffel_test_xxx
WB_TAVILY_API_KEY=tvly-xxx

# ---- Guardrails (AWS Bedrock) ----
# The guardrail must already exist in WB_AWS_REGION. boto3 authenticates with the
# standard AWS_* keys below — use an IAM user allowed to call bedrock:ApplyGuardrail.
WB_GUARDRAILS_BACKEND=bedrock
WB_AWS_REGION=ap-south-1
WB_BEDROCK_GUARDRAIL_ID=your-guardrail-id
WB_BEDROCK_GUARDRAIL_VERSION=DRAFT
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=ap-south-1
