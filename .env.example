# ---- LLM ----
WB_LLM_PROVIDER=openai          # openai | gemini | anthropic
# Leave WB_LLM_MODEL / WB_EMBEDDING_MODEL blank to use the provider default.
WB_LLM_MODEL=
WB_EMBEDDING_MODEL=
# OpenAI
WB_OPENAI_API_KEY=sk-...
# Google Gemini (https://aistudio.google.com/apikey)
WB_GOOGLE_API_KEY=

# ---- Travel providers ----
WB_FLIGHT_PROVIDER=duffel       # duffel (default) | amadeus
WB_GEO_PROVIDER=openmeteo       # openmeteo (keyless, default) | amadeus

# Duffel — flights (sign up free at https://app.duffel.com/join, use a duffel_test_ token)
WB_DUFFEL_API_KEY=duffel_test_...
WB_DUFFEL_VERSION=v2
# Stays (hotels) requires requesting access: https://duffel.com/contact-us
# In sandbox, test hotels only exist at fixed coords — set true to see hotels in the demo.
WB_DUFFEL_USE_TEST_HOTELS=true

# Amadeus (legacy/optional — self-service portal is being decommissioned)
# If set, enables hotels + activities. Leave blank to run flights-only.
WB_AMADEUS_CLIENT_ID=
WB_AMADEUS_CLIENT_SECRET=
WB_AMADEUS_ENV=test             # test | production

# ---- Web search (research + interim hotels) ----
# Free key at https://app.tavily.com  (also powers WB_HOTEL_PROVIDER=tavily)
WB_TAVILY_API_KEY=

# ---- Hotels source ----
# duffel (Stays, needs access) | tavily (web suggestions) | amadeus | none
WB_HOTEL_PROVIDER=tavily

# ---- Maps ----
WB_GOOGLE_MAPS_API_KEY=

# ---- Weather ----
WB_OPENWEATHER_API_KEY=

# ---- Currency (keyless default) ----
WB_EXCHANGE_RATES_BASE_URL=https://api.frankfurter.dev/v1

# ---- Infra ----
WB_DATABASE_URL=postgresql://wanderbot:wanderbot@localhost:5432/wanderbot
WB_REDIS_URL=redis://localhost:6379/0

# ---- Security ----
WB_JWT_SECRET=change-me-in-prod
WB_JWT_ALGORITHM=HS256

# ---- Guardrails (AWS Bedrock) ----
WB_GUARDRAILS_BACKEND=auto        # auto | regex | bedrock
WB_AWS_REGION=us-east-1
WB_BEDROCK_GUARDRAIL_ID=          # e.g. gr-abc123 (leave blank to use regex)
WB_BEDROCK_GUARDRAIL_VERSION=DRAFT
# AWS credentials via standard chain: AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / role

# ---- App ----
WB_ENV=local                   # local | staging | production
WB_LOG_LEVEL=INFO
WB_MCP_SERVER_CMD=python -m mcp_server.server
WB_MAX_GRAPH_ITERATIONS=12
WB_REQUEST_COST_BUDGET_USD=0.50

# ---- Observability (optional) ----
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
WB_OTEL_EXPORTER_OTLP_ENDPOINT=
